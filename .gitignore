# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
*.pyc

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Secrets — never commit; the API key comes only from the environment
.env
*.key
*.pem
credentials.json

# Large external dependencies (download separately)
codeql-linux64/
codeql/

# Raw datasets (download from official sources)
experiment/
datasets/raw/

# Experiment artifacts (generated locally or too large)
artifacts/experiments/
artifacts/joern/
artifacts/real_llm/
artifacts/codeql_*/

# Keep paper release data (sanitized, intended for reviewers)
!artifacts/paper_release_data/

# Large binary and compressed files
*.db
*.sqlite
*.sarif
*.zip
*.tar.gz
*.tgz

# Logs
*.log
logs/

# Model checkpoints and weights
*.pt
*.pth
*.ckpt
checkpoints/
models/*.bin
models/*.safetensors

# Temporary files
tmp/
temp/
.cache/
